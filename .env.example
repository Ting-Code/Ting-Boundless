# Copy to .env and fill in. NEVER commit .env (see .gitignore).
#
# Profiles: native-local (default below), docker-full, cloud — see docs/ENV_PROFILES.md
# Local dev defaults target locally installed Postgres / Redis / RabbitMQ / MinIO.
# Production placeholders (commented) are fake cloud endpoints — replace before deploy.

# =============================================================================
# Local development (default) — locally installed services on localhost
# =============================================================================

# --- Postgres ---
POSTGRES_USER=ting
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_SSLMODE=disable
# Superuser password for scripts/setup-local.ps1 only (local dev, never commit real prod secrets)
# POSTGRES_ADMIN_PASSWORD=your-postgres-install-password
# Per-service databases on the same instance:
#   app_db    — user-service, business-service, auth-service, file-service
#   logto_db  — Logto
#   audit_db  — audit-service
AUDIT_DB=audit_db
LOGTO_DB=logto_db
# Optional: restricted runtime user for audit-service (migrations use POSTGRES_USER).
# AUDIT_POSTGRES_USER=audit_writer
# AUDIT_POSTGRES_PASSWORD=change-me-audit

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- RabbitMQ ---
# Requires Erlang 27 for RabbitMQ 4.3.x (see scripts/start-rabbitmq.bat)
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# --- Object storage (S3-compatible; local MinIO or skip until needed) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=ting-boundless
# FILE_MAX_BYTES=20971520
# FILE_PRESIGN_SECONDS=3600

# --- HTTP listen (per service; optional overrides) ---
# BUSINESS_HTTP_ADDR=:3005   # Nest business-service (default :3005; avoids Logto :3001)

# --- Service URLs (go run on host; adjust ports if needed) ---
USER_SERVICE_URL=http://127.0.0.1:8081
BUSINESS_SERVICE_URL=http://127.0.0.1:3005
FILE_SERVICE_URL=http://127.0.0.1:8083
AUTH_SERVICE_URL=http://127.0.0.1:8084
AUDIT_SERVICE_URL=http://127.0.0.1:8085
# Next.js public site (Gateway proxies non-/v1 paths here)
SITE_SERVICE_URL=http://127.0.0.1:3006
# Server-side fetch from @ting/site to Gateway (not sent to browser)
GATEWAY_URL=http://127.0.0.1:8080
# Worker outbox dispatcher (polls business_outbox → audit-service)
# OUTBOX_POLL_INTERVAL=5
# OUTBOX_BATCH_SIZE=20

# --- Identity (Logto; local install or Docker) ---
OIDC_ISSUER=http://127.0.0.1:3001/oidc
OIDC_JWKS_URL=http://127.0.0.1:3001/oidc/jwks
OIDC_AUDIENCE=https://api.ting-boundless.local
OIDC_CLIENT_ID=change-me
OIDC_CLIENT_SECRET=change-me
# OIDC_RESOURCE=https://api.ting-boundless.local
# OIDC_REDIRECT_URI=http://127.0.0.1:8080/callback
# GATEWAY_PUBLIC_URL=http://127.0.0.1:8080
# OIDC_SCOPES=openid profile email
# Local dev: cookie BFF without Logto (requires Redis + GATEWAY_DEV_JWT_SECRET)
# Set false after Logto app is configured (see docs/LOGTO_SETUP.md)
GATEWAY_BFF_DEV_LOGIN=true
# Comma-separated anonymous paths at Gateway (no end-user JWT/cookie required).
# Syntax: =/path exact match; /path prefix match. See go/services/gateway/README.md.
# GATEWAY_ANON_PREFIXES==/healthz,=/readyz,=/metrics,=/sign-in,=/callback,=/sign-out,=/internal/webhooks/logto,=/,/v1/business/ping,/admin,/v1/auth/
# /sign-in/dev is added automatically only when GATEWAY_BFF_DEV_LOGIN=true.
SESSION_COOKIE_NAME=tb_session
# Set-Cookie Secure: true when APP_ENV=production unless overridden
# SESSION_COOKIE_SECURE=true
# Local dev JWT (HS256) when Logto is not running — NEVER use in production
GATEWAY_DEV_JWT_SECRET=dev-only-change-me

# --- Internal service-to-service ---
# Gateway injects X-Internal-Token on upstream proxy; services reject forged identity headers without it.
# Dev: leave empty to skip GatewayTrust (local go run only). Production: required (see APP_ENV below).
INTERNAL_API_TOKEN=dev-internal-token-change-me
# APP_ENV=production enforces INTERNAL_API_TOKEN at startup (set in docker-compose.prod.yml).
# APP_ENV=development
# REQUIRE_INTERNAL_TOKEN=true  # optional strict mode without full production profile

# --- auth-service (WeChat mini-program + internal JWT issuer) ---
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me
# Local dev without WeChat credentials: openid = mock_<code>
WECHAT_MOCK_MODE=true
AUTH_OIDC_ISSUER=http://127.0.0.1:8084/oidc
AUTH_JWKS_URL=http://127.0.0.1:8084/v1/auth/jwks
# Production: PEM PKCS#1 or PKCS#8 RSA private key (never commit)
# AUTH_JWT_PRIVATE_KEY_PEM=
# AUTH_JWT_ACCESS_TTL_SECONDS=3600
# Logto webhook (Console → Webhooks → signing key)
# LOGTO_WEBHOOK_SIGNING_KEY=
# Local dev only: accept unsigned webhooks when signing key is unset
# LOGTO_WEBHOOK_SKIP_VERIFY=true

# --- Observability ---
# Local stack: make up-obs → Grafana http://localhost:3003 (see deploy/otel/README.md)
# GATEWAY_RATE_LIMIT_ENABLED=true
# GATEWAY_RATE_LIMIT_REDIS=true   # use Redis when REDIS_ADDR is available
# GATEWAY_RATE_LIMIT_AUTH_RPS=5
# GATEWAY_RATE_LIMIT_AUTH_BURST=10
# GATEWAY_RATE_LIMIT_GENERAL_RPS=50
# GATEWAY_RATE_LIMIT_GENERAL_BURST=100
# GATEWAY_SENSITIVE_PREFIXES=/v1/files/   # revocation check on these paths; use "-" to disable
# AUTH_REVOCATION_REDIS_PREFIX=auth:revoked:
# AUTH_REVOCATION_TTL=720h (optional local: docker compose otel-collector on :4317 gRPC / :4318 HTTP / :8889 metrics)
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_LOGS_EXPORTER=otlp   # set to "none" to skip OTLP log fan-out (stdout JSON always on)
# OTEL_SERVICE_NAME defaults to each service name (gateway, auth-service, ...)
LOG_LEVEL=info

# --- HTTP listen addresses (when running multiple services locally) ---
# HTTP_ADDR=:8080   # gateway default
# user-service:8081 file-service:8083 auth-service:8084 audit-service:8085 worker:8086
# business-service (Nest):3005 — node/apps/business-service, not in Go compose

# =============================================================================
# Docker full stack (make up) — override these when ALL services run in compose
# See docs/ENV_PROFILES.md. compose.yml also sets gateway upstream URLs.
# =============================================================================
# POSTGRES_HOST=postgres
# REDIS_ADDR=redis:6379
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# RABBITMQ_PREFETCH=10
# RABBITMQ_MAX_RETRIES=3
# OIDC_JWKS_URL=http://logto:3001/oidc/jwks
# USER_SERVICE_URL=http://user-service:8081
# AUTH_SERVICE_URL=http://auth-service:8084
# AUDIT_SERVICE_URL=http://audit-service:8085
# BUSINESS_SERVICE_URL=http://host.docker.internal:3005

# =============================================================================
# Production / Tencent Cloud — see docs/DEPLOY_TENCENT.md
# =============================================================================
# GATEWAY_PUBLIC_URL=https://api.example.com
# OIDC_REDIRECT_URI=https://api.example.com/callback
# POSTGRES_HOST=postgres-xxx.sql.tencentcdb.com
# POSTGRES_SSLMODE=require
# AUDIT_POSTGRES_USER=audit_writer
# AUDIT_POSTGRES_PASSWORD=***
# REDIS_ADDR=redis-placeholder:6379
# RABBITMQ_URL=amqp://ting:***@mq-placeholder:5672/
# S3_ENDPOINT=https://oss-placeholder.aliyuncs.com
# OIDC_ISSUER=https://auth.example.com/oidc
# OIDC_JWKS_URL=https://auth.example.com/oidc/jwks
