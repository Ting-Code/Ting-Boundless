# Copy to .env and fill in. NEVER commit .env (see .gitignore).
#
# Local dev defaults target locally installed Postgres / Redis / RabbitMQ / MinIO.
# Production placeholders (commented) are fake cloud endpoints — replace before deploy.

# =============================================================================
# Local development (default) — locally installed services on localhost
# =============================================================================

# --- Postgres ---
POSTGRES_USER=ting
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_SSLMODE=disable
# Superuser password for scripts/setup-local.ps1 only (local dev, never commit real prod secrets)
# POSTGRES_ADMIN_PASSWORD=your-postgres-install-password
# Per-service databases on the same instance:
#   app_db    — user-service, business-service, auth-service, file-service
#   logto_db  — Logto
#   audit_db  — audit-service
AUDIT_DB=audit_db
LOGTO_DB=logto_db

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- Object storage (S3-compatible; local MinIO or skip until needed) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=ting-boundless

# --- Service URLs (go run on host; adjust ports if needed) ---
USER_SERVICE_URL=http://127.0.0.1:8081
BUSINESS_SERVICE_URL=http://127.0.0.1:8082
FILE_SERVICE_URL=http://127.0.0.1:8083
AUTH_SERVICE_URL=http://127.0.0.1:8084

# --- Identity (Logto; local install or Docker) ---
OIDC_ISSUER=http://127.0.0.1:3001/oidc
OIDC_JWKS_URL=http://127.0.0.1:3001/oidc/jwks
OIDC_AUDIENCE=ting-boundless

# --- auth-service ---
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_NAME=unset
LOG_LEVEL=info

# --- HTTP listen addresses (when running multiple services locally) ---
# HTTP_ADDR=:8080   # gateway default
# user-service:8081 business-service:8082 file-service:8083 auth-service:8084 audit-service:8085 worker:8086

# =============================================================================
# Production / cloud placeholders — uncomment and replace before deploy
# =============================================================================
# POSTGRES_HOST=rm-xxx.pg.rds.aliyuncs.com
# POSTGRES_SSLMODE=require
# REDIS_ADDR=redis-placeholder:6379
# RABBITMQ_URL=amqp://ting:***@mq-placeholder:5672/
# S3_ENDPOINT=https://oss-placeholder.aliyuncs.com
# OIDC_ISSUER=https://auth.example.com/oidc
# OIDC_JWKS_URL=https://auth.example.com/oidc/jwks
