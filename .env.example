# Copy to .env and fill in. NEVER commit .env (see .gitignore).
#
# Local dev defaults target locally installed Postgres / Redis / RabbitMQ / MinIO.
# Production placeholders (commented) are fake cloud endpoints — replace before deploy.

# =============================================================================
# Local development (default) — locally installed services on localhost
# =============================================================================

# --- Postgres ---
POSTGRES_USER=ting
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_SSLMODE=disable
# Superuser password for scripts/setup-local.ps1 only (local dev, never commit real prod secrets)
# POSTGRES_ADMIN_PASSWORD=your-postgres-install-password
# Per-service databases on the same instance:
#   app_db    — user-service, business-service, auth-service, file-service
#   logto_db  — Logto
#   audit_db  — audit-service
AUDIT_DB=audit_db
LOGTO_DB=logto_db

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- RabbitMQ ---
# Requires Erlang 27 for RabbitMQ 4.3.x (see scripts/start-rabbitmq.bat)
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# --- Object storage (S3-compatible; local MinIO or skip until needed) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=ting-boundless

# --- HTTP listen (per service; optional overrides) ---
# BUSINESS_HTTP_ADDR=:3005   # Nest business-service (default :3005; avoids Logto :3001)

# --- Service URLs (go run on host; adjust ports if needed) ---
USER_SERVICE_URL=http://127.0.0.1:8081
BUSINESS_SERVICE_URL=http://127.0.0.1:3005
FILE_SERVICE_URL=http://127.0.0.1:8083
AUTH_SERVICE_URL=http://127.0.0.1:8084

# --- Identity (Logto; local install or Docker) ---
OIDC_ISSUER=http://127.0.0.1:3001/oidc
OIDC_JWKS_URL=http://127.0.0.1:3001/oidc/jwks
OIDC_AUDIENCE=https://api.ting-boundless.local
OIDC_CLIENT_ID=change-me
OIDC_CLIENT_SECRET=change-me
# OIDC_RESOURCE=https://api.ting-boundless.local
# OIDC_REDIRECT_URI=http://127.0.0.1:8080/callback
# GATEWAY_PUBLIC_URL=http://127.0.0.1:8080
# OIDC_SCOPES=openid profile email
# Local dev: cookie BFF without Logto (requires Redis + GATEWAY_DEV_JWT_SECRET)
# Set false after Logto app is configured (see docs/LOGTO_SETUP.md)
GATEWAY_BFF_DEV_LOGIN=true
# Comma-separated path prefixes allowed without auth (defaults: /healthz,/sign-in,/admin,/v1/business/ping,...)
# GATEWAY_ANON_PREFIXES=/healthz,/readyz,/metrics,/sign-in,/callback,/sign-out,/admin,/v1/business/ping,/v1/auth/
SESSION_COOKIE_NAME=tb_session
# Local dev JWT (HS256) when Logto is not running — NEVER use in production
GATEWAY_DEV_JWT_SECRET=dev-only-change-me

# --- Internal service-to-service ---
# Gateway injects X-Internal-Token on upstream proxy; services reject forged identity headers without it.
# Leave empty in local dev to disable the check; set in staging/production.
INTERNAL_API_TOKEN=dev-internal-token-change-me

# --- auth-service ---
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_NAME=unset
LOG_LEVEL=info

# --- HTTP listen addresses (when running multiple services locally) ---
# HTTP_ADDR=:8080   # gateway default
# user-service:8081 file-service:8083 auth-service:8084 audit-service:8085 worker:8086
# business-service (Nest):3005 — node/apps/business-service, not in Go compose

# =============================================================================
# Production / Tencent Cloud — see docs/DEPLOY_TENCENT.md
# =============================================================================
# GATEWAY_PUBLIC_URL=https://api.example.com
# OIDC_REDIRECT_URI=https://api.example.com/callback
# POSTGRES_HOST=postgres-xxx.sql.tencentcdb.com
# POSTGRES_SSLMODE=require
# REDIS_ADDR=redis-placeholder:6379
# RABBITMQ_URL=amqp://ting:***@mq-placeholder:5672/
# S3_ENDPOINT=https://oss-placeholder.aliyuncs.com
# OIDC_ISSUER=https://auth.example.com/oidc
# OIDC_JWKS_URL=https://auth.example.com/oidc/jwks
