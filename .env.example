# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# Secrets are injected at deploy time; this file lists required keys only.

# --- Postgres ---
POSTGRES_USER=ting
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_ADDR=redis:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://ting:change-me@rabbitmq:5672/

# --- Object storage (S3-compatible: MinIO / Aliyun OSS) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=ting-boundless

# --- Identity (Logto) ---
# OIDC issuer + JWKS the Gateway uses to verify tokens.
OIDC_ISSUER=http://logto:3001/oidc
OIDC_JWKS_URL=http://logto:3001/oidc/jwks
OIDC_AUDIENCE=ting-boundless

# --- auth-service ---
# WeChat mini-program credentials for code2session.
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=unset
LOG_LEVEL=info
