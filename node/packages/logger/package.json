{
  "name": "@ting/logger",
  "version": "0.0.0",
  "private": true,
  "description": "ECS-style structured logger shared by Nest and web apps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "default": "./dist/nest/index.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "default": "./dist/otel.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.1",
    "@opentelemetry/auto-instrumentations-node": "^0.55.3",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.57.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-logs": "^0.57.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "rxjs": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "rxjs": "^7.8.2",
    "typescript": "^5.8.2"
  }
}
