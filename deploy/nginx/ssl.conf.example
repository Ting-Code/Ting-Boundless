# Production TLS nginx config (see nginx.prod.conf).
# Certs: mount fullchain.pem + privkey.pem to /etc/nginx/certs/
#
# Local certbot example:
#   certbot certonly --standalone -d api.example.com
#   cp /etc/letsencrypt/live/api.example.com/fullchain.pem deploy/nginx/certs/
#   cp /etc/letsencrypt/live/api.example.com/privkey.pem deploy/nginx/certs/
#
# CVM: docker compose -f deploy/docker-compose.prod.yml up -d
# TCR nginx image is built with NGINX_MAIN=nginx.prod.conf (see Dockerfile.nginx).
